# 인증 방식: refresh, env, selenium 중 하나를 사용한다.
CG_AUTH_PROVIDER=refresh

# 백엔드 기본 주소와 필요 시 덮어쓸 상세 URL들
CG_BASE_URL=
# CG_CONFIG_URL=
# CG_UPLOAD_URL=
# CG_REFRESH_URL=
# CG_LOGIN_URL=

# refresh/env/selenium 인증에 사용하는 값들
CG_REFRESH_TOKEN=
CG_ACCESS_TOKEN=
LOGIN_ID=
LOGIN_PASSWORD=

# 인증 및 요청 관련 공통 옵션
CG_TOKEN_REFRESH_MARGIN_SECONDS=60
CG_REQUEST_TIMEOUT_SECONDS=10
CG_CHROME_LOGIN_WAIT_SECONDS=5
CG_CAPTURE_ROOT=captures

# 무단투기 추적 파라미터
CG_TRACK_MOVEMENT_THRESHOLD=10
CG_TRACK_STATIONARY_FRAMES=5
CG_TRACK_MATCH_DISTANCE=30
CG_TRACK_MAX_MISSING_FRAMES=15
CG_TRACK_AREA_GROWTH_RATIO=1.1

# 이벤트 영상 생성 및 프레임 저장 옵션
CG_MAX_STORED_FRAMES=1000
CG_RECORD_FPS=5
CG_RECORD_PRE_FRAMES=35
CG_RECORD_POST_FRAMES=35
CG_FRAME_WIDTH=2304
CG_FRAME_HEIGHT=1296
CG_SAVE_WIDTH=640
CG_SAVE_HEIGHT=480
CG_RTSP_PORT=554

# 모델 경로와 추론 confidence
CG_MODEL_PATH=yolo11m_train.engine
CG_DETECTOR_CONFIDENCE=0.5

# SSE 연결/재시도와 로그 레벨
CG_POLLER_CONNECT_TIMEOUT=5
CG_POLLER_READ_TIMEOUT=5
CG_POLLER_RETRY_SECONDS=5
CG_POLLER_STALE_TIMEOUT=60
CG_LOG_LEVEL=INFO
